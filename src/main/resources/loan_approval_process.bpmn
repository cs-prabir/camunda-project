        <di:waypoint x="1138" y="370" />
        <di:waypoint x="1202" y="370" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
