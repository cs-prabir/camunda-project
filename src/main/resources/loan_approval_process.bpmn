      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Timeout_di" bpmnElement="EndEvent_Timeout">
        <dc:Bounds x="1202" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EventSubprocess_Cancel_di" bpmnElement="EventSubprocess_Cancel" isExpanded="true">
        <dc:Bounds x="150" y="500" width="350" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Cancel_di" bpmnElement="StartEvent_Cancel">
        <dc:Bounds x="190" y="580" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Cleanup_di" bpmnElement="ServiceTask_Cleanup">
        <dc:Bounds x="280" y="558" width="100" height="80" />
