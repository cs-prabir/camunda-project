      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Sub2_di" bpmnElement="Flow_Sub2">
        <di:waypoint x="380" y="598" />
        <di:waypoint x="430" y="598" />
      </bpmndi:BPMNEdge>
