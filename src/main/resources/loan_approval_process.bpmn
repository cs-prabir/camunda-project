        <di:waypoint x="510" y="400" />
        <di:waypoint x="510" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToRiskXOR_di" bpmnElement="Flow_ToRiskXOR">
