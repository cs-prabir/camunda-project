<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="ce5fd89" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:message id="Message_Start" name="LoanApplicationSubmitted">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_Cancel" name="CancelApplication">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_CustomerFeedback" name="CustomerFeedback">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_ReceiveDocs" name="LoanDocumentsReceived">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_PolicyUpdated" name="LoanPolicyUpdated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_Complaint" name="CustomerComplaint">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_Withdrawal" name="CustomerWithdrawal">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:signal id="Signal_LoanApproved" name="Signal_LoanApproved" />
  <bpmn:process id="loan_approval_process" name="Loan Approval System" isExecutable="true">
    <!-- Start -->
    <bpmn:startEvent id="StartEvent_Message" name="Application Submitted">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Start" messageRef="Message_Start" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartEvent_Message" targetRef="Gateway_ParallelSplit" />

    <!-- Phase 1: Parallel Verification -->
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Parallel Split">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCredit</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToFraud</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_ToCredit" sourceRef="Gateway_ParallelSplit" targetRef="ServiceTask_CreditCheck" />
    <bpmn:serviceTask id="ServiceTask_CreditCheck" name="Credit Check API">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="credit-check" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCredit</bpmn:incoming>
      <bpmn:outgoing>Flow_FromCredit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_CreditError" name="Credit API Failed" attachedToRef="ServiceTask_CreditCheck">
      <bpmn:outgoing>Flow_ErrorEnd</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1" errorRef="Error_CreditAPI" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_ToFraud" sourceRef="Gateway_ParallelSplit" targetRef="ServiceTask_FraudCheck" />
    <bpmn:serviceTask id="ServiceTask_FraudCheck" name="Fraud Check System">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="fraud-check" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToFraud</bpmn:incoming>
      <bpmn:outgoing>Flow_FromFraud</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Parallel Join">
      <bpmn:incoming>Flow_FromCredit</bpmn:incoming>
      <bpmn:incoming>Flow_FromFraud</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInclusive</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_FromCredit" sourceRef="ServiceTask_CreditCheck" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_FromFraud" sourceRef="ServiceTask_FraudCheck" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_ToInclusive" sourceRef="Gateway_ParallelJoin" targetRef="Gateway_Inclusive" />

    <!-- Phase 2: Inclusive Optional Paths -->
    <bpmn:inclusiveGateway id="Gateway_Inclusive" name="Optional Services?" default="Flow_ToRisk">
      <bpmn:incoming>Flow_ToInclusive</bpmn:incoming>
      <bpmn:outgoing>Flow_ToRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToInsurance</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sequenceFlow id="Flow_ToRisk" sourceRef="Gateway_Inclusive" targetRef="Gateway_Risk" />
    <bpmn:sequenceFlow id="Flow_ToInsurance" name="Add Insurance" sourceRef="Gateway_Inclusive" targetRef="ServiceTask_Insurance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=addInsurance = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="ServiceTask_Insurance" name="Insurance Provision">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="insurance-provision" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToInsurance</bpmn:incoming>
      <bpmn:outgoing>Flow_FromInsur</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="Gateway_InclusiveJoin">
      <bpmn:incoming>Flow_FromInsur</bpmn:incoming>
      <bpmn:incoming>Flow_AfterRiskAccepted</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDocAcq</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:sequenceFlow id="Flow_FromInsur" sourceRef="ServiceTask_Insurance" targetRef="Gateway_InclusiveJoin" />

    <!-- Phase 3: Risk Evaluation -->
    <bpmn:exclusiveGateway id="Gateway_Risk" name="Risk Acceptable?" default="Flow_RiskRejected">
      <bpmn:incoming>Flow_ToRisk</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskAccepted</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_RiskAccepted" name="Score &#62; 600" sourceRef="Gateway_Risk" targetRef="Gateway_InclusiveJoin">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=creditScore &gt; 600</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RiskRejected" sourceRef="Gateway_Risk" targetRef="EndEvent_Rejected" />
    <bpmn:endEvent id="EndEvent_Rejected" name="Loan Rejected (High Risk)">
      <bpmn:incoming>Flow_RiskRejected</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Phase 4: Acquisition & Verification -->
    <bpmn:sequenceFlow id="Flow_ToDocAcq" sourceRef="Gateway_InclusiveJoin" targetRef="SubProcess_DocAcquisition" />
    <bpmn:subProcess id="SubProcess_DocAcquisition" name="Document Acquisition">
      <bpmn:incoming>Flow_ToDocAcq</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDocVerif</bpmn:outgoing>
      <bpmn:startEvent id="StartEvent_DocAcq" name="Start">
        <bpmn:outgoing>Flow_ToReq</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_ToReq" sourceRef="StartEvent_DocAcq" targetRef="ServiceTask_RequestDocs" />
      <bpmn:serviceTask id="ServiceTask_RequestDocs" name="Request Documents">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="request-docs-worker" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_ToReq</bpmn:incoming>
        <bpmn:outgoing>Flow_ToRec</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_ToRec" sourceRef="ServiceTask_RequestDocs" targetRef="ReceiveTask_ReceiveDocs" />
      <bpmn:receiveTask id="ReceiveTask_ReceiveDocs" name="Receive Documents" messageRef="Message_ReceiveDocs">
        <bpmn:extensionElements>
          <zeebe:subscription correlationKey="=applicationId" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_ToRec</bpmn:incoming>
        <bpmn:outgoing>Flow_ToEndAcq</bpmn:outgoing>
      </bpmn:receiveTask>
      <bpmn:endEvent id="EndEvent_DocAcq" name="Acquired">
        <bpmn:incoming>Flow_ToEndAcq</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_ToEndAcq" sourceRef="ReceiveTask_ReceiveDocs" targetRef="EndEvent_DocAcq" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_ToDocVerif" sourceRef="SubProcess_DocAcquisition" targetRef="CallActivity_DocVerif" />
    <bpmn:callActivity id="CallActivity_DocVerif" name="Verify Documents" calledElement="document_verification">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="document_verification" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToDocVerif</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDMN</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_ToDMN" sourceRef="CallActivity_DocVerif" targetRef="BusinessRuleTask_ApproveAmount" />

    <!-- Phase 5: Decisioning -->
    <bpmn:businessRuleTask id="BusinessRuleTask_ApproveAmount" name="Approve Loan Amount">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="loan-decision" resultVariable="approval" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToDMN</bpmn:incoming>
      <bpmn:outgoing>Flow_AfterDMN</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_AfterDMN" sourceRef="BusinessRuleTask_ApproveAmount" targetRef="Gateway_DMNResult" />
    <bpmn:exclusiveGateway id="Gateway_DMNResult" name="Review Needed?" default="Flow_ToRejectedDMN">
      <bpmn:incoming>Flow_AfterDMN</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoApproved</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedsReview</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToRejectedDMN</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_AutoApproved" name="Approved" sourceRef="Gateway_DMNResult" targetRef="IntermediateCatch_PolicyUpdated">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approval = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NeedsReview" name="Manual Review" sourceRef="Gateway_DMNResult" targetRef="UserTask_ManualReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needsReview = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToRejectedDMN" sourceRef="Gateway_DMNResult" targetRef="EndEvent_AutoRejected" />
    <bpmn:endEvent id="EndEvent_AutoRejected" name="Auto Rejected">
      <bpmn:incoming>Flow_ToRejectedDMN</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="UserTask_ManualReview" name="Manual Final Review">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NeedsReview</bpmn:incoming>
      <bpmn:outgoing>Flow_FromManual</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryEvent_SLA" name="SLA 24h" cancelActivity="false" attachedToRef="UserTask_ManualReview">
      <bpmn:outgoing>Flow_Escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Withdraw" name="Withdrawn" attachedToRef="UserTask_ManualReview">
      <bpmn:outgoing>Flow_Withdrawal</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Withdraw" messageRef="Message_Withdrawal" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_Escalation" sourceRef="BoundaryEvent_SLA" targetRef="ServiceTask_Escalate" />
    <bpmn:serviceTask id="ServiceTask_Escalate" name="Send Escalation Notice">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="escalation-worker" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Escalation</bpmn:incoming>
      <bpmn:outgoing>Flow_EndEscalation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Escalated">
      <bpmn:incoming>Flow_EndEscalation</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_EndEscalation" sourceRef="ServiceTask_Escalate" targetRef="EndEvent_Escalated" />
    <bpmn:sequenceFlow id="Flow_Withdrawal" sourceRef="BoundaryEvent_Withdraw" targetRef="EndEvent_Withdrawn" />
    <bpmn:endEvent id="EndEvent_Withdrawn" name="Process Withdrawn">
      <bpmn:incoming>Flow_Withdrawal</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_FromManual" sourceRef="UserTask_ManualReview" targetRef="IntermediateCatch_PolicyUpdated" />

    <!-- Phase 6: Closing -->
    <bpmn:intermediateCatchEvent id="IntermediateCatch_PolicyUpdated" name="Wait for Policy Update">
      <bpmn:incoming>Flow_FromManual</bpmn:incoming>
      <bpmn:incoming>Flow_AutoApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEventGateway</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_PolicyUpdate" messageRef="Message_PolicyUpdated" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ToEventGateway" sourceRef="IntermediateCatch_PolicyUpdated" targetRef="Gateway_WaitContract" />
    <bpmn:eventBasedGateway id="Gateway_WaitContract" name="Wait for Signature">
      <bpmn:incoming>Flow_ToEventGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_FeedCatch</bpmn:outgoing>
      <bpmn:outgoing>Flow_TimeCatch</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="IntermediateCatch_Feedback" name="Feedback Received">
      <bpmn:incoming>Flow_FeedCatch</bpmn:incoming>
      <bpmn:outgoing>Flow_ToBroadcasting</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Feedback" messageRef="Message_CustomerFeedback" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="IntermediateCatch_Timeout" name="Signature Timeout (7d)">
      <bpmn:incoming>Flow_TimeCatch</bpmn:incoming>
      <bpmn:outgoing>Flow_ToExpired</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_Timeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_FeedCatch" sourceRef="Gateway_WaitContract" targetRef="IntermediateCatch_Feedback" />
    <bpmn:sequenceFlow id="Flow_TimeCatch" sourceRef="Gateway_WaitContract" targetRef="IntermediateCatch_Timeout" />
    <bpmn:sequenceFlow id="Flow_ToExpired" sourceRef="IntermediateCatch_Timeout" targetRef="EndEvent_Expired" />
    <bpmn:endEvent id="EndEvent_Expired" name="Application Expired">
      <bpmn:incoming>Flow_ToExpired</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Broadcaster -->
    <bpmn:sequenceFlow id="Flow_ToBroadcasting" sourceRef="IntermediateCatch_Feedback" targetRef="SignalThrow_LoanApproved" />
    <bpmn:intermediateThrowEvent id="SignalThrow_LoanApproved" name="Broadcast Approval">
      <bpmn:incoming>Flow_ToBroadcasting</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndSuccess</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalEventDefinition_Approved" signalRef="Signal_LoanApproved" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="EndEvent_Success" name="Loan Approved">
      <bpmn:incoming>Flow_ToEndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToEndSuccess" sourceRef="SignalThrow_LoanApproved" targetRef="EndEvent_Success" />

    <!-- Global Handling -->
    <bpmn:endEvent id="EndEvent_Error" name="Fatal Error">
      <bpmn:incoming>Flow_ErrorEnd</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_Fatal" errorRef="Error_Process" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ErrorEnd" sourceRef="BoundaryEvent_CreditError" targetRef="EndEvent_Error" />

    <!-- Event Subprocesses -->
    <bpmn:subProcess id="EventSub_Cancel" name="Cancellation Handler" triggeredByEvent="true">
      <bpmn:startEvent id="Start_Cancel" name="Abort Request">
        <bpmn:outgoing>Flow_CancelToCleanup</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MsgCancelDef" messageRef="Message_Cancel" />
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Cleanup" name="Cleanup Resources">
        <bpmn:extensionElements><zeebe:taskDefinition type="cleanup" /></bpmn:extensionElements>
        <bpmn:incoming>Flow_CancelToCleanup</bpmn:incoming>
        <bpmn:outgoing>Flow_ToCancelEnd</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="End_Canceled" name="Process Terminated">
        <bpmn:incoming>Flow_ToCancelEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_CancelToCleanup" sourceRef="Start_Cancel" targetRef="Task_Cleanup" />
      <bpmn:sequenceFlow id="Flow_ToCancelEnd" sourceRef="Task_Cleanup" targetRef="End_Canceled" />
    </bpmn:subProcess>

    <bpmn:subProcess id="EventSub_Complaint" name="Complaint Tracker" triggeredByEvent="true">
      <bpmn:startEvent id="Start_Complaint" name="Complaint Received" isInterrupting="false">
        <bpmn:outgoing>Flow_CompToTask</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MsgCompDef" messageRef="Message_Complaint" />
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_LogComp" name="Log Complaint Entry">
        <bpmn:extensionElements><zeebe:taskDefinition type="log-complaint" /></bpmn:extensionElements>
        <bpmn:incoming>Flow_CompToTask</bpmn:incoming>
        <bpmn:outgoing>Flow_ToCompEnd</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="End_Comp" name="Logged">
        <bpmn:incoming>Flow_ToCompEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_CompToTask" sourceRef="Start_Complaint" targetRef="Task_LogComp" />
      <bpmn:sequenceFlow id="Flow_ToCompEnd" sourceRef="Task_LogComp" targetRef="End_Comp" />
    </bpmn:subProcess>

    <bpmn:subProcess id="EventSub_Pulse" name="Daily Health Check" triggeredByEvent="true">
      <bpmn:startEvent id="Start_Pulse" name="Every 24h" isInterrupting="false">
        <bpmn:outgoing>Flow_PulseToTask</bpmn:outgoing>
        <bpmn:timerEventDefinition id="TimerDef_Pulse">
          <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1D</bpmn:timeCycle>
        </bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_Pulse" name="Report Instance Status">
        <bpmn:extensionElements><zeebe:taskDefinition type="instance-pulse" /></bpmn:extensionElements>
        <bpmn:incoming>Flow_PulseToTask</bpmn:incoming>
        <bpmn:outgoing>Flow_ToPulseEnd</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="End_Pulse" name="Pulse Sent">
        <bpmn:incoming>Flow_ToPulseEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_PulseToTask" sourceRef="Start_Pulse" targetRef="Task_Pulse" />
      <bpmn:sequenceFlow id="Flow_ToPulseEnd" sourceRef="Task_Pulse" targetRef="End_Pulse" />
    </bpmn:subProcess>

  </bpmn:process>

  <bpmn:error id="Error_CreditAPI" name="Credit API Error" errorCode="CREDIT_ERROR" />
  <bpmn:error id="Error_Process" name="Process Error" errorCode="PROCESS_FATAL" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="loan_approval_process">
      <bpmndi:BPMNShape id="StartEvent_Message_di" bpmnElement="StartEvent_Message">
        <dc:Bounds x="160" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ParallelSplit_di" bpmnElement="Gateway_ParallelSplit">
        <dc:Bounds x="250" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_CreditCheck_di" bpmnElement="ServiceTask_CreditCheck">
        <dc:Bounds x="350" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_FraudCheck_di" bpmnElement="ServiceTask_FraudCheck">
        <dc:Bounds x="350" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ParallelJoin_di" bpmnElement="Gateway_ParallelJoin">
        <dc:Bounds x="500" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Inclusive_di" bpmnElement="Gateway_Inclusive">
        <dc:Bounds x="600" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Insurance_di" bpmnElement="ServiceTask_Insurance">
        <dc:Bounds x="700" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Risk_di" bpmnElement="Gateway_Risk" isMarkerVisible="true">
        <dc:Bounds x="725" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InclusiveJoin_di" bpmnElement="Gateway_InclusiveJoin">
        <dc:Bounds x="850" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_DocAcquisition_di" bpmnElement="SubProcess_DocAcquisition" isExpanded="true">
        <dc:Bounds x="950" y="100" width="400" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_DocAcq_di" bpmnElement="StartEvent_DocAcq">
        <dc:Bounds x="970" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_RequestDocs_di" bpmnElement="ServiceTask_RequestDocs">
        <dc:Bounds x="1040" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveDocs_di" bpmnElement="ReceiveTask_ReceiveDocs">
