          <dc:Bounds x="674" y="433" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallActivity_DocVerif_di" bpmnElement="CallActivity_DocVerif">
        <dc:Bounds x="690" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ManagerApproval_di" bpmnElement="UserTask_ManagerApproval">
        <dc:Bounds x="850" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ScriptTask_Escalation_di" bpmnElement="ScriptTask_Escalation">
        <dc:Bounds x="980" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SLA_di" bpmnElement="EndEvent_SLA">
        <dc:Bounds x="1132" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_EventBased_di" bpmnElement="Gateway_EventBased">
        <dc:Bounds x="1005" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
