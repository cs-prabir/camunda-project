<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="ce5fd89" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:message id="Message_Start" name="LoanApplicationSubmitted">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_Cancel" name="CancelApplication">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_CustomerFeedback" name="CustomerFeedback">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=applicationId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="loan_approval_process" name="Loan Approval System" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Message" name="Application Submitted">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_Start" messageRef="Message_Start" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartEvent_Message" targetRef="Gateway_ParallelSplit" />
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Parallel Processing">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCredit</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToFraud</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_ToCredit" sourceRef="Gateway_ParallelSplit" targetRef="ServiceTask_CreditCheck" />
    <bpmn:serviceTask id="ServiceTask_CreditCheck" name="Credit Check API">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="credit-check" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCredit</bpmn:incoming>
      <bpmn:outgoing>Flow_FromCredit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_CreditError" name="Credit API Failed" attachedToRef="ServiceTask_CreditCheck">
      <bpmn:outgoing>Flow_ErrorEnd</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1" errorRef="Error_CreditAPI" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_ErrorEnd" sourceRef="BoundaryEvent_CreditError" targetRef="EndEvent_Error" />
    <bpmn:endEvent id="EndEvent_Error" name="Process Failed">
      <bpmn:incoming>Flow_ErrorEnd</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_End" errorRef="Error_Process" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToFraud" sourceRef="Gateway_ParallelSplit" targetRef="ServiceTask_FraudCheck" />
    <bpmn:serviceTask id="ServiceTask_FraudCheck" name="Fraud Check System">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="fraud-check" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToFraud</bpmn:incoming>
      <bpmn:outgoing>Flow_FromFraud</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_FromCredit" sourceRef="ServiceTask_CreditCheck" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_FromFraud" sourceRef="ServiceTask_FraudCheck" targetRef="Gateway_ParallelJoin" />
    <bpmn:parallelGateway id="Gateway_ParallelJoin">
      <bpmn:incoming>Flow_FromCredit</bpmn:incoming>
      <bpmn:incoming>Flow_FromFraud</bpmn:incoming>
      <bpmn:outgoing>Flow_ToRiskXOR</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_ToRiskXOR" sourceRef="Gateway_ParallelJoin" targetRef="Gateway_Risk" />
    <bpmn:exclusiveGateway id="Gateway_Risk" name="Is Risk Accepted?" default="Flow_RiskRejected">
      <bpmn:incoming>Flow_ToRiskXOR</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskAccepted</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_RiskRejected" sourceRef="Gateway_Risk" targetRef="EndEvent_Rejected" />
    <bpmn:endEvent id="EndEvent_Rejected" name="Loan Rejected">
      <bpmn:incoming>Flow_RiskRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_RiskAccepted" name="Score &#62; 600 and Fraud = false" sourceRef="Gateway_Risk" targetRef="CallActivity_DocVerif">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=creditScore &gt; 600 and fraudDetected = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:callActivity id="CallActivity_DocVerif" name="Document Verification" calledElement="document_verification">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="document_verification" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=applicationId" target="applicationId" />
          <zeebe:output source="=documentValid" target="documentValid" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RiskAccepted</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUserTask</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_ToUserTask" sourceRef="CallActivity_DocVerif" targetRef="UserTask_ManagerApproval" />
    <bpmn:userTask id="UserTask_ManagerApproval" name="Manager Approval">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="manager-approval-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToUserTask</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEventBased</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryEvent_SLA" name="SLA 24h" cancelActivity="false" attachedToRef="UserTask_ManagerApproval">
      <bpmn:outgoing>Flow_SLAEscalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT3M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_SLAEscalation" sourceRef="BoundaryEvent_SLA" targetRef="ScriptTask_Escalation" />
    <bpmn:serviceTask id="ScriptTask_Escalation" name="Trigger Escalation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="script-worker-escalation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SLAEscalation</bpmn:incoming>
      <bpmn:outgoing>Flow_SLAEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_SLAEnd" sourceRef="ScriptTask_Escalation" targetRef="EndEvent_SLA" />
    <bpmn:endEvent id="EndEvent_SLA" name="Escalated">
      <bpmn:incoming>Flow_SLAEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToEventBased" sourceRef="UserTask_ManagerApproval" targetRef="Gateway_EventBased" />
    <bpmn:eventBasedGateway id="Gateway_EventBased" name="Wait for Contract">
      <bpmn:incoming>Flow_ToEventBased</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCatchMessage</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToCatchTimer</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_ToCatchMessage" sourceRef="Gateway_EventBased" targetRef="IntermediateCatch_CustomerSig" />
    <bpmn:intermediateCatchEvent id="IntermediateCatch_CustomerSig" name="Customer Feedback">
      <bpmn:incoming>Flow_ToCatchMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ToApproveEnd</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_2" messageRef="Message_CustomerFeedback" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ToCatchTimer" sourceRef="Gateway_EventBased" targetRef="IntermediateCatch_Timeout" />
    <bpmn:intermediateCatchEvent id="IntermediateCatch_Timeout" name="Timeout 7 Days">
      <bpmn:incoming>Flow_ToCatchTimer</bpmn:incoming>
      <bpmn:outgoing>Flow_TimeoutToReject</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_2">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ToApproveEnd" sourceRef="IntermediateCatch_CustomerSig" targetRef="EndEvent_Approved" />
    <bpmn:endEvent id="EndEvent_Approved" name="Loan Approved">
      <bpmn:incoming>Flow_ToApproveEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_TimeoutToReject" sourceRef="IntermediateCatch_Timeout" targetRef="EndEvent_Timeout" />
    <bpmn:endEvent id="EndEvent_Timeout" name="Timeout Failure">
      <bpmn:incoming>Flow_TimeoutToReject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="EventSubprocess_Cancel" name="Cancellation Handler" triggeredByEvent="true">
      <bpmn:startEvent id="StartEvent_Cancel" name="Cancel App">
        <bpmn:extensionElements />
        <bpmn:outgoing>Flow_Sub1</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_3" messageRef="Message_Cancel" />
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_Sub1" sourceRef="StartEvent_Cancel" targetRef="ServiceTask_Cleanup" />
      <bpmn:serviceTask id="ServiceTask_Cleanup" name="Cleanup Resources">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="cleanup-worker" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_Sub1</bpmn:incoming>
        <bpmn:outgoing>Flow_Sub2</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_Sub2" sourceRef="ServiceTask_Cleanup" targetRef="EndEvent_Canceled" />
      <bpmn:endEvent id="EndEvent_Canceled" name="Canceled">
        <bpmn:incoming>Flow_Sub2</bpmn:incoming>
      </bpmn:endEvent>
    </bpmn:subProcess>
  </bpmn:process>
  <bpmn:error id="Error_CreditAPI" name="Credit API Error" errorCode="CREDIT_ERROR" />
  <bpmn:error id="Error_Process" name="Process Error" errorCode="CREDIT_ERROR" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="loan_approval_process">
      <bpmndi:BPMNShape id="StartEvent_Message_di" bpmnElement="StartEvent_Message">
        <dc:Bounds x="152" y="302" width="36" height="36" />
