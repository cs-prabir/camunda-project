          <dc:Bounds x="288" y="153" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_di" bpmnElement="Flow_Start">
        <di:waypoint x="188" y="320" />
        <di:waypoint x="235" y="320" />
      </bpmndi:BPMNEdge>
